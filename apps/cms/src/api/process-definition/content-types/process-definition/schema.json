{
  "kind": "collectionType",
  "collectionName": "process_definitions",
  "info": {
    "singularName": "process-definition",
    "pluralName": "process-definitions",
    "displayName": "Process Definition",
    "description": "Default automotive supplier process taxonomy (COP and support processes)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": { "localized": true }
  },
  "attributes": {
    "processId": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "name": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "category": {
      "type": "enumeration",
      "enum": ["COP", "SUP"],
      "required": true
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
