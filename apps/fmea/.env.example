# Copy this file to .env.local and fill in your real values.
# This file is gitignored — never commit it.

# ── Strapi CMS ───────────────────────────────────────────
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=

# ── AI Provider ──────────────────────────────────────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=

# ── Redis (Upstash KV) ──────────────────────────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Encryption ───────────────────────────────────────────
CODE_HASH_PEPPER=

# ── Session ──────────────────────────────────────────────
# Must be at least 32 characters. Generate: openssl rand -base64 32
SESSION_SECRET=
SESSION_TTL_SECONDS=86400

# ── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── URLs ─────────────────────────────────────────────────
BASE_URL=http://localhost:3003
NEXT_PUBLIC_TOOL_URL=http://localhost:3003
NEXT_PUBLIC_LANDING_PAGE_URL=http://localhost:3000

# ── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=
CREDIT_DELIVERY_EMAIL_FROM="IATF Solutions <noreply@iatf-solutions.com>"
ADMIN_EMAIL=
